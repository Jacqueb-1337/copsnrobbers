<?xml version="1.0" encoding="utf-8"?>
<merge android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout style="@style/KamcordProfileSettingsItemContainer">
        <ImageView android:id="@id/icon" style="@style/KamcordProfileSettingsItemIcon" />
        <LinearLayout android:orientation="vertical" android:layout_width="0.0dip" android:layout_height="wrap_content" android:layout_weight="1.0">
            <TextView android:id="@id/network_name" style="@style/KamcordProfileSettingsNetworkText" />

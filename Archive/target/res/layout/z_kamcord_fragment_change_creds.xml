<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:background="@android:color/transparent" android:padding="@dimen/kamcordChangeCredsPadding" android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:background="#ffffffff" android:paddingLeft="@dimen/kamcordChangeCredsPadding" android:paddingRight="@dimen/kamcordChangeCredsPadding" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/kamcordChangeCredsPadding">
        <EditText android:id="@id/currentPasswordEditText" android:hint="@string/kamcordCurrentPassword" android:inputType="textPassword" android:imeOptions="actionNext" style="@style/KamcordEditText" />
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:background="#ffffffff" android:paddingLeft="@dimen/kamcordChangeCredsPadding" android:paddingRight="@dimen/kamcordChangeCredsPadding" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/kamcordChangeCredsPadding">
        <EditText android:id="@id/newCredEditText" android:imeOptions="actionNext" style="@style/KamcordEditText" />
        <View android:background="@color/kamcordDividerColor" android:layout_width="fill_parent" android:layout_height="@dimen/kamcordDividerWidth" />
        <EditText android:id="@id/newCredAgainEditText" android:imeOptions="actionDone" style="@style/KamcordEditText" />
    </LinearLayout>
    <Button android:id="@id/changeCredButton" style="@style/KamcordButton" />
</LinearLayout>